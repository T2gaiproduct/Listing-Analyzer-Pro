modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5555
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 19145
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ADMIN_USER_IDS = "user_3DaXBiPeghgkEWTwdlZksSiwaum,user_3DabnbhF3hsSNpiJgHuLMAvjtNL,user_3EzhfJwLDGeGLtqFjRuelZXzzOR,user_3EziEdSA54Cmr7DT8HpY4Y3095c"
